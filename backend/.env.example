# Copy to .env and adjust as needed.

# Where DuckDB file + parquet data live (relative to repo root or absolute)
DATA_DIR=../data

# CORS — frontend dev origin
FRONTEND_ORIGIN=http://localhost:3000

# Default risk-free rate (annual) used for Sharpe/Sortino
RISK_FREE_RATE=0.03

# Background price scheduler: periodically snapshot the whole KR board and
# upsert today's OHLCV bar into DuckDB so the price series accumulates forward.
PRICE_INGEST=true
# Seconds between snapshots (default 300 = 5 min)
PRICE_INGEST_INTERVAL=300

# ─────────────────────────────────────────────────────────────────────────────
# 추가 데이터 소스 API 키 (전부 무료 발급). 없어도 한국/미국 시세·펀더멘털·급등락·
# 개장예측·데일리리포트·미래테마 등 대부분의 크롤링은 pykrx/yfinance 로 자동 동작.
# ─────────────────────────────────────────────────────────────────────────────

# 부동산 실거래가 (아파트 매매 거래액·거래량 지도) — https://www.data.go.kr
DATA_GO_KR_KEY=

# 한국은행 ECOS (M2·가계신용·주택매매가격지수) — https://ecos.bok.or.kr/api
ECOS_API_KEY=

# DART 전자공시 (5% 대량보유자 실명·재무제표) — https://opendart.fss.or.kr
DART_API_KEY=

# Finnhub (해외 종목 펀더멘털 — 글로벌 경쟁지도) — https://finnhub.io
FINNHUB_API_KEY=

# Anthropic Claude (AI 주가 예측·급등락 원인 서술) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# 회원가입 이메일 인증코드 발송 SMTP. 외부 노출(터널) 시 반드시 설정할 것.
# 미설정이면 인증코드가 발송되지 않는다(응답 노출도 기본 차단 — 아래 플래그 참고).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=앱비밀번호16자리
# SMTP_FROM=you@gmail.com

# 인증코드를 HTTP 응답(dev_code)에 노출할지. 기본 false(안전).
# true 로 켜면 이메일 인증이 무력화되어 누구나 계정 탈취 가능 → 로컬 개발 전용,
# 공개 URL(ngrok·cloudflared)에 노출된 상태에선 절대 켜지 말 것.
# AUTH_EXPOSE_DEV_CODE=false
